        <mxCell id="A9PJk6A9yRQXVEmx5Pzm-8" value="&lt;b&gt;Риски:&lt;/b&gt;&amp;nbsp;&lt;div&gt;- искажение данных&lt;/div&gt;&lt;div&gt;- некачественные данные&lt;/div&gt;&lt;div&gt;Степень:&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;i&gt;Незначительный&lt;/i&gt;&lt;/b&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;fillColor=#FFF2CC;" vertex="1" parent="1">
